{
    "name": "astral-php/astral",
    "description": "Astral MVC — Framework PHP 8.x minimaliste, moderne et orienté objet",
    "type": "project",
    "version": "1.1.2",
    "license": "MIT",
    "keywords": ["php", "mvc", "framework", "microframework", "di", "psr"],
    "require": {
        "php": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "src/Core/",
            "Database\\": "src/Database/",
            "Controller\\": "src/Controller/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}
