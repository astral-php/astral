# ============================================================
# Application — copiez ce fichier en .env et adaptez les valeurs
# ============================================================
APP_NAME="ASTRAL-MVC"
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_CHARSET=UTF-8
APP_BASE_URL=

# ============================================================
# Base de données
# ============================================================
DB_DRIVER=sqlite
DB_DATABASE=database/astral.sqlite

# MySQL
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mvc_db
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# ============================================================
# Authentification
# ============================================================
# direct  → l'utilisateur accède directement après inscription
# confirm → un e-mail de confirmation est envoyé
AUTH_REGISTRATION=direct

# ============================================================
# Mailer
# ============================================================
MAIL_DRIVER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@monapp.com
MAIL_FROM_NAME="ASTRAL-MVC"

# ============================================================
# API REST
# ============================================================
# Générer une clé avec : php -r "echo bin2hex(random_bytes(32));"
API_KEY=change-me-generate-a-secure-key